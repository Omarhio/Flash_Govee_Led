# Copy this file to .env and fill in your values.
# Find your device IP in your router's DHCP table or the Govee app.
# Enable "LAN Control" in Govee app > device settings before running.
DEVICE_IP=192.168.1.xxx

# Optional — defaults shown
FLASH_THRESHOLD=200.0
CAPTURE_BBOX=[300,300,500,500]
POLL_INTERVAL=0.05
DISCOVERY_TIMEOUT=10.0
