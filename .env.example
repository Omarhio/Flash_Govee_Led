# Copy this file to .env and fill in your values.
# Find your device IP in your router's DHCP table or the Govee app.
# Enable "LAN Control" in Govee app > device settings before running.
DEVICE_IP=192.168.1.xxx

# Screen region to monitor [left, top, right, bottom]
# Use a large central area for better uniformity detection.
# Default targets the center of a 1920x1080 screen.
CAPTURE_BBOX=[640,300,1280,780]

# Flash detector — optional, defaults shown
BASELINE_WINDOW=20        # frames in rolling baseline (~1s at 50ms poll)
RELATIVE_SPIKE=0.30       # brightness must be 30% above baseline
MIN_SPIKE=25.0            # minimum absolute brightness increase (0-255)

# Valorant-specific filters
MAX_UNIFORMITY=50.0       # lower = stricter (flash = uniform screen = low std)
MAX_SATURATION=80.0       # lower = stricter (flash = white/pale = low RGB spread)
POLL_INTERVAL=0.05
